# ============================================
# AI Maturity Platform — Environment Variables
# ============================================

# Application
APP_NAME=AI Maturity Assessment Platform
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Frontend
VITE_API_URL=http://localhost:8000
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=ai-maturity
VITE_KEYCLOAK_CLIENT_ID=frontend-spa

# Yandex Object Storage (локально используем MinIO)
YANDEX_S3_ENDPOINT=http://localhost:9000
YANDEX_S3_ACCESS_KEY=minioadmin
YANDEX_S3_SECRET_KEY=minioadmin
YANDEX_S3_BUCKET=ai-maturity-data
YANDEX_S3_REGION=ru-central1

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=ai-maturity
KEYCLOAK_CLIENT_ID=backend-api
KEYCLOAK_CLIENT_SECRET=your-client-secret-here
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Baserow CRM
BASEROW_URL=http://localhost:3001
BASEROW_API_TOKEN=your-baserow-api-token
BASEROW_LEADS_TABLE_ID=1

# SMTP (Yandex 360)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@company.ru
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=AI Maturity Platform
SMTP_FROM_EMAIL=noreply@company.ru

# Data Storage
DATA_STORAGE_PATH=./data_storage
RAW_AUDITS_PATH=./data_storage/raw_audits
AGGREGATED_PATH=./data_storage/aggregated
REPORTS_PATH=./data_storage/reports
EXPORTS_PATH=./data_storage/exports
LOGS_PATH=./data_storage/logs

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json